# Database Configuration
# Para desenvolvimento local, use SQLite:
DATABASE_URL=sqlite:///./cattle_control.db

# Para produção com PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/cattle_control

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_STR=/api/v1
PROJECT_NAME=Cattle Control API
PROJECT_VERSION=0.1.0

# Debug Mode (desativar em produção!)
DEBUG=True

# CORS Origins (adicione os domínios do frontend)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:5173"]
